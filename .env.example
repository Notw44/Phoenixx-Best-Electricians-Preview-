# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project (used server-side).
SUPABASE_URL="https://mtrnykwwqsidagagpfvr.supabase.co"

# SUPABASE_ANON_KEY: The Anon/Public key of your Supabase project (used server-side).
SUPABASE_ANON_KEY="sb_publishable_n_i-oNRxPwTdaCn6kB-ImA_5SLORhCG"

# VITE_SUPABASE_URL: The URL of your Supabase project (exposed client-side).
VITE_SUPABASE_URL="https://mtrnykwwqsidagagpfvr.supabase.co"

# VITE_SUPABASE_ANON_KEY: The Anon/Public key of your Supabase project (exposed client-side).
VITE_SUPABASE_ANON_KEY="sb_publishable_n_i-oNRxPwTdaCn6kB-ImA_5SLORhCG"

